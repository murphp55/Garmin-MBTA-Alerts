<?xml version="1.0" encoding="UTF-8"?>
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq"
             version="3.2.0" type="watch-app">
  <iq:id>com.yourname.mbtaalerts</iq:id>
  <iq:products>
    <!-- Add/trim targets you care about -->
    <iq:product id="fenix7"/>
    <iq:product id="epix2"/>
    <iq:product id="fr955"/>
    <iq:product id="vivoactive5"/>
  </iq:products>

  <iq:application entry="App" launcherIcon="@Drawables.LauncherIcon"
                  minSdkVersion="4.1.0" manifestVersion="3.2.0">
    <iq:name>MBTA Alerts</iq:name>
    <iq:permissions>
      <iq:uses-permission id="Communications"/>   <!-- makeWebRequest -->
      <iq:uses-permission id="Positioning"/>      <!-- if you add nearest-stop -->
    </iq:permissions>
    <iq:languages>en</iq:languages>
    <iq:barrels/>
    <iq:settings>
      <iq:setting id="mbtaApiKey" type="string" required="true" />
      <iq:setting id="stopId" type="string" required="true" />
      <iq:setting id="routeFilter" type="string" required="false"/>
      <iq:setting id="direction" type="number" required="false" />
      <iq:setting id="maxRows" type="number" required="false" default="5"/>
    </iq:settings>
  </iq:application>
</iq:manifest>
